<Window x:Class="QuickMetadata.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuickMetadata"
        mc:Ignorable="d"
        Title="QuickMetadata" Height="600" Width="620" ResizeMode="CanResize"
        Background="#1a1a1a"
        Foreground="#e0e0e0"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Farben -->
        <SolidColorBrush x:Key="BgPrimary"     Color="#1a1a1a"/>
        <SolidColorBrush x:Key="BgSecondary"   Color="#242424"/>
        <SolidColorBrush x:Key="BgHover"       Color="#2e2e2e"/>
        <SolidColorBrush x:Key="AccentColor"   Color="#4a9eff"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="#e0e0e0"/>
        <SolidColorBrush x:Key="TextMuted"     Color="#888888"/>
        <SolidColorBrush x:Key="BorderColor"   Color="#333333"/>

        <!-- ListBox Style -->
        <Style TargetType="ListBox">
            <Setter Property="Background"        Value="#242424"/>
            <Setter Property="BorderBrush"       Value="#333333"/>
            <Setter Property="BorderThickness"   Value="1"/>
            <Setter Property="Foreground"        Value="#e0e0e0"/>
            <Setter Property="Padding"           Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <!-- ListBoxItem Style -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding"           Value="10 7"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Foreground"        Value="#c0c0c0"/>
            <Setter Property="FontSize"          Value="12"/>
            <Setter Property="Background"        Value="Transparent"/>
            <Setter Property="BorderThickness"   Value="0"/>
            <Setter Property="Cursor"            Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2e2e2e"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1e3a5f"/>
                    <Setter Property="Foreground" Value="#4a9eff"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TextBox Style -->
        <Style TargetType="TextBox">
            <Setter Property="Background"        Value="#2a2a2a"/>
            <Setter Property="Foreground"        Value="#e0e0e0"/>
            <Setter Property="BorderBrush"       Value="#383838"/>
            <Setter Property="BorderThickness"   Value="1"/>
            <Setter Property="Padding"           Value="6 4"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="FontSize"          Value="12"/>
            <Setter Property="Height"            Value="28"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush"        Value="#4a9eff"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#4a9eff"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="GridSplitter">
            <Setter Property="Background"        Value="#2a2a2a"/>
        </Style>

        <!-- Label Style -->
        <Style TargetType="Label">
            <Setter Property="Foreground"        Value="#888888"/>
            <Setter Property="FontSize"          Value="11"/>
            <Setter Property="Padding"           Value="0 4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

    </Window.Resources>
    
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition MinWidth="50" Width="Auto" MaxWidth="160"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Dateiliste -->
        <ListBox Grid.Column="0" x:Name="lb_FileList"
                 DisplayMemberPath="FileName"
                 SelectionChanged="lb_FileList_SelectionChanged"/>

        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

        <!-- Detailansicht -->
        <Grid Grid.Column="2" Margin="10,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Label Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                   x:Name="lb_ImageName"
                   Content=""
                   FontSize="14" FontWeight="Bold"
                   HorizontalAlignment="Center"/>

            <Label Grid.Row="1" Grid.Column="0" Content="Drone Model"/>
            <TextBox Grid.Row="1" Grid.Column="1" x:Name="tb_DroneModel" IsReadOnly="True" MouseDoubleClick="TextBox_DoubleClick"/>

            <Label Grid.Row="2" Grid.Column="0" Content="Date/Time" ToolTip="Copy Date and Time" MouseDoubleClick="DateTimeLabel_DoubleClick" Cursor="Hand"/>
            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                <TextBox x:Name="tb_Date" IsReadOnly="True" Width="90" MouseDoubleClick="TextBox_DoubleClick"/>
                <Label Content="/" Padding="2, 0, 0, 0"/>
                <TextBox x:Name="tb_Time" IsReadOnly="True" Width="75" Margin="4 0 0 0" MouseDoubleClick="TextBox_DoubleClick"/>
            </StackPanel>
            
            <Label Grid.Row="3" Grid.Column="0" Content="Altitude Type"/>
            <TextBox Grid.Row="3" Grid.Column="1" x:Name="tb_AltitudeType" IsReadOnly="True" MouseDoubleClick="TextBox_DoubleClick"/>

            <Label Grid.Row="4" Grid.Column="0" Content="Absolute Altitude"/>
            <TextBox Grid.Row="4" Grid.Column="1" x:Name="tb_AbsoluteAltitude" IsReadOnly="True" MouseDoubleClick="TextBox_DoubleClick"/>

            <Label Grid.Row="5" Grid.Column="0" Content="Relative Altitude"/>
            <TextBox Grid.Row="5" Grid.Column="1" x:Name="tb_RelativeAltitude" IsReadOnly="True" MouseDoubleClick="TextBox_DoubleClick"/>

            <Label Grid.Row="6" Grid.Column="0" Content="Coordinates" ToolTip="Copy Latitude and Longitude" FontWeight="Bold" MouseDoubleClick="CoordinatesLabel_DoubleClick" Cursor="Hand"/>

            <Label Grid.Row="7" Grid.Column="0" Content="Latitude"/>
            <TextBox Grid.Row="7" Grid.Column="1" x:Name="tb_Latitude" IsReadOnly="True" MouseDoubleClick="TextBox_DoubleClick"/>

            <Label Grid.Row="8" Grid.Column="0" Content="Longitude"/>
            <TextBox Grid.Row="8" Grid.Column="1" x:Name="tb_Longitude" IsReadOnly="True" MouseDoubleClick="TextBox_DoubleClick"/>

            <Image Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="2"
                   x:Name="img_Preview"
                   MaxHeight="200"
                   Margin="0 8 0 8"
                   Stretch="Uniform"
                   HorizontalAlignment="Center"/>

        </Grid>
    </Grid>
</Window>